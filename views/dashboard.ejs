<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Solo-Bot Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --bg-dark: #1e1e24; --bg-side: #151519; --accent: #d95e40; --text: #ffffff; }
        body { margin: 0; font-family: sans-serif; background: var(--bg-dark); color: var(--text); display: flex; height: 100vh; }
        
        /* Sidebar des serveurs */
        .server-sidebar { width: 72px; background: var(--bg-side); display: flex; flex-direction: column; align-items: center; padding-top: 15px; gap: 12px; border-right: 1px solid #000; }
        .server-icon { width: 48px; height: 48px; border-radius: 50%; background: #36393f; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; overflow: hidden; text-decoration: none; color: white; }
        .server-icon:hover { border-radius: 15px; background: var(--accent); }
        .server-icon img { width: 100%; height: 100%; object-fit: cover; }

        /* Contenu */
        .main { flex: 1; padding: 40px; overflow-y: auto; }
        .login-container { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; }
        .btn-discord { background: #5865F2; color: white; padding: 15px 30px; border-radius: 5px; text-decoration: none; font-weight: bold; font-size: 18px; transition: 0.3s; }
        .btn-discord:hover { background: #4752c4; transform: translateY(-2px); }
        
        .card { background: #2b2b31; padding: 20px; border-radius: 8px; margin-top: 20px; border-left: 5px solid var(--accent); }
        .btn-invite { background: #43b581; color: white; padding: 8px 15px; border-radius: 4px; text-decoration: none; font-size: 13px; }
    </style>
</head>
<body>

    <% if (!user) { %>
        <div class="login-container">
            <img src="https://brandlogovector.com/wp-content/uploads/2020/06/Discord-Logo-Icon-White-768x576.png" width="80">
            <h1 style="margin: 20px 0;">Solo-Bot Manager</h1>
            <a href="/login" class="btn-discord"><i class="fa-brands fa-discord"></i> Se connecter avec Discord</a>
        </div>
    <% } else { %>
        <div class="server-sidebar">
            <a href="/dashboard" class="server-icon" title="Accueil"><i class="fa-solid fa-house"></i></a>
            <hr style="width: 40px; border: 1px solid #333;">
            <% guilds.forEach(guild => { %>
                <a href="/dashboard?guild=<%= guild.id %>" class="server-icon" title="<%= guild.name %>">
                    <% if (guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png">
                    <% } else { %>
                        <%= guild.name.charAt(0) %>
                    <% } %>
                </a>
            <% }) %>
            <a href="https://discord.com/api/oauth2/authorize?client_id=<%= bot.user.id %>&permissions=8&scope=bot" class="server-icon" style="color: #43b581;"><i class="fa-solid fa-plus"></i></a>
        </div>

        <div class="main">
            <header style="display: flex; justify-content: space-between; align-items: center;">
                <h1>Bonjour, <%= user.username %> 👋</h1>
                <a href="/logout" style="color: #ff4747; text-decoration: none;">Déconnexion</a>
            </header>

            <div class="card">
                <h3>Gestion des serveurs</h3>
                <p>Sélectionne un serveur à gauche pour le configurer ou invite le bot sur un nouveau serveur :</p>
                <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 20px;">
                    <% guilds.forEach(guild => { %>
                        <div style="background: #1e1e24; padding: 15px; border-radius: 8px; text-align: center; width: 150px;">
                            <p style="font-size: 14px; height: 40px; overflow: hidden;"><%= guild.name %></p>
                            <a href="https://discord.com/api/oauth2/authorize?client_id=<%= bot.user.id %>&permissions=8&scope=bot&guild_id=<%= guild.id %>" class="btn-invite">Inviter / Gérer</a>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    <% } %>

</body>
</html>
