<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Solo-Invites Dashboard</title>
    <style>
        body { font-family: sans-serif; background: #2f3136; color: white; margin: 0; }
        .navbar { background: #202225; padding: 15px; display: flex; justify-content: space-between; align-items: center; }
        .container { padding: 20px; display: flex; flex-wrap: wrap; gap: 20px; }
        .card { background: #36393f; padding: 20px; border-radius: 8px; width: 200px; text-align: center; }
        .card img { border-radius: 50%; width: 80px; margin-bottom: 10px; }
        .btn { background: #5865f2; color: white; padding: 10px; text-decoration: none; border-radius: 5px; display: inline-block; margin-top: 10px; }
        .login-btn { background: #5865f2; color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px; font-weight: bold; }
    </style>
</head>
<body>

    <div class="navbar">
        <h2>Solo-Invites</h2>
        <% if (user) { %>
            <div><%= user.username %> <a href="/logout" style="color: #ff4747; margin-left: 10px;">Déconnexion</a></div>
        <% } %>
    </div>

    <div class="container">
        <% if (!user) { %>
            <div style="width: 100%; text-align: center; margin-top: 100px;">
                <h1>Bienvenue sur le Tracker d'invitations</h1>
                <br><br>
                <a href="/login" class="login-btn">Se connecter avec Discord</a>
            </div>
        <% } else { %>
            <% guilds.forEach(guild => { %>
                <div class="card">
                    <% if (guild.icon) { %>
                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png">
                    <% } else { %>
                        <div style="width:80px; height:80px; background:#444; border-radius:50%; margin:0 auto 10px; display:flex; align-items:center; justify-content:center;">?</div>
                    <% } %>
                    <h3><%= guild.name %></h3>
                    <a href="https://discord.com/api/oauth2/authorize?client_id=<%= clientId %>&permissions=8&scope=bot&guild_id=<%= guild.id %>" class="btn">Inviter le Bot</a>
                </div>
            <% }) %>
        <% } %>
    </div>

</body>
</html>
